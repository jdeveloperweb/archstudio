# Copy to infra/.env and fill. Generate secrets with:
#   openssl rand -hex 24            -> APP_JWT_SECRET
#   openssl rand -base64 32         -> APP_ENC_KEY
#   openssl rand -hex 16            -> POSTGRES_PASSWORD
POSTGRES_PASSWORD=change-me
APP_JWT_SECRET=change-me-min-32-chars-long-secret-value
APP_ENC_KEY=base64-of-32-random-bytes==
APP_PUBLIC_URL=https://studio.mjolnix.com.br
APP_COOKIE_SECURE=true

# Email verification. With MAIL_ENABLED=false the verification/reset links are
# written to the API logs (dev/bootstrap). Set true + SMTP creds for real email.
MAIL_ENABLED=false
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USER=no-reply@studio.mjolnix.com.br
MAIL_PASS=
MAIL_FROM=ArchStudio <no-reply@studio.mjolnix.com.br>
