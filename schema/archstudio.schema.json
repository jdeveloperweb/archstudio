{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://archstudio.mjolnix.com.br/schema/archstudio.schema.json",
  "title": "ArchStudio diagram spec",
  "description": "Agent-friendly architecture diagram spec for ArchStudio (https://archstudio.mjolnix.com.br). Omit node x/y and the built-in auto-layout arranges the flow left-to-right following the edges. Load via the app's 📂 button, via URL '#d=j:<base64url(JSON)>' or '?src=<url>'.",
  "type": "object",
  "required": ["nodes"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Diagram title shown in the top bar and in exports."
    },
    "boxes": {
      "type": "array",
      "description": "Dashed group containers (e.g. 'AWS us-east-1', 'On-premise'). Nodes reference them via their 'box' property; the box is sized automatically around its members.",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": ["string", "number"], "description": "Key referenced by nodes' 'box' property." },
          "label": { "type": "string", "maxLength": 40 },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "description": "Optional hex color; a palette color is picked when omitted." }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": ["string", "number"], "description": "Unique key referenced by edges." },
          "type": {
            "type": "string",
            "description": "Component type. Unknown values fall back to 'api'.",
            "enum": [
              "user", "browser", "mobile", "iot", "partner",
              "route53", "cloudfront", "waf", "apigw", "alb", "nlb", "vpc",
              "ec2", "ecs", "eks", "fargate", "lambda", "batch",
              "s3", "rds", "aurora", "dynamodb", "elasticache", "redshift", "opensearch", "glacier",
              "sqs", "sns", "eventbridge", "kinesis", "msk", "stepfn", "ses",
              "iam", "cognito", "secretsmgr", "kms", "cloudwatch", "xray",
              "cloudrun", "gke", "cloudfn", "gce", "gcs", "cloudsql", "firestore", "bigquery", "pubsub", "memorystore", "vertexai",
              "appservice", "aks", "azfunc", "azvm", "blob", "azsql", "cosmosdb", "servicebus", "eventhubs", "frontdoor", "entra",
              "llm", "aiagent", "vectordb", "embeddings", "mcp", "guardrail", "gpu",
              "funcao", "edgefn", "faasqueue", "container",
              "api", "worker", "queue", "stream", "dlq", "outbox", "db", "cache", "lb", "gateway", "auth", "sched", "obs", "extern", "k8s", "cdngen", "storagegen",
              "server", "vm", "dbonprem", "mainframe", "firewall", "nas", "ad", "vpn", "dc"
            ]
          },
          "label": { "type": "string", "maxLength": 42, "description": "Display name; defaults to the type's catalog name." },
          "box": { "type": ["string", "number"], "description": "Id of the box this node belongs to." },
          "s": { "type": "number", "minimum": 0.6, "maximum": 2.2, "description": "Scale factor (default 1)." },
          "style": { "type": "string", "enum": ["card", "icon"], "description": "'card' = full card (default); 'icon' = borderless large icon." },
          "x": { "type": "number", "description": "Optional; omit to use auto-layout." },
          "y": { "type": "number", "description": "Optional; omit to use auto-layout." }
        }
      }
    },
    "edges": {
      "type": "array",
      "description": "Directed connections between nodes. In IaC generation these define wiring and least-privilege IAM.",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": ["string", "number"] },
          "to": { "type": ["string", "number"] },
          "label": { "type": "string", "maxLength": 40, "description": "Protocol/action, e.g. 'SQL', 'publica', '202 Accepted'." },
          "dash": { "type": "boolean", "description": "Dashed line — conventionally async/background/fallback paths." },
          "heads": { "type": "string", "enum": ["end", "both", "none"], "default": "end" },
          "w": { "type": "number", "minimum": 1, "maximum": 6, "description": "Stroke width (default 2)." }
        }
      }
    },
    "texts": {
      "type": "array",
      "description": "Free-floating annotations — use them for key architectural decisions and constraints.",
      "items": {
        "type": "object",
        "required": ["text"],
        "additionalProperties": false,
        "properties": {
          "text": { "type": "string", "maxLength": 300 },
          "size": { "type": "number", "minimum": 10, "maximum": 34, "default": 14 },
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    }
  }
}
